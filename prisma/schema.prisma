// Prisma schema — MongoDB
// Ship or Die Africa: Communauté de builders africains francophones

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) models ----------
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // ---- Ship or Die core ----
  role          Role      @default(USER)
  githubUsername String?
  githubVerified Boolean  @default(false)
  bio           String?
  avatarUrl     String?

  // ---- Telegram (notifications) ----
  telegramChatId    String?
  telegramLinkCode  String? @unique

  // ---- Préférences de notifications ----
  notifyDailyReminder   Boolean @default(true)
  notifyDeadlineAlert   Boolean @default(true)
  notifyTrophyUnlocked  Boolean @default(true)
  notifySomeoneShipped  Boolean @default(false)

  // ---- Cohorte ----
  cohortId      String?   @db.ObjectId
  joinedAt      DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  missions      Mission[]
  payments      Payment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

// ---------- Mission (projet à shipper en 30j) ----------
model Mission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  title       String
  description String
  url         String?
  repoUrl     String?

  status      MissionStatus @default(IN_PROGRESS)
  startedAt   DateTime @default(now())
  deadline    DateTime
  shippedAt   DateTime?

  // ---- Jours de pause (max 3) ----
  // Chaque pause consomme 1 jour et prolonge la deadline d'1 jour
  pauseDaysUsed Int @default(0)

  // ---- La Récolte (page publique des projets shippés) ----
  tagline       String?  // Pitch en une phrase du projet
  screenshotUrl String?  // URL d'une capture d'écran du projet
  isPublic      Boolean  @default(true)  // Visible sur /recolte ou non

  // ---- Gamification (mis à jour par sync-mission.ts) ----
  commitCount  Int      @default(0)
  currentStreak Int     @default(0)
  lastCommitAt DateTime?

  // ---- Historique des commits par jour ----
  // Format: { "2026-07-01": 3, "2026-07-02": 0, ... }
  // Construit à partir des dates de commits lors de la synchronisation
  // Clés en UTC (YYYY-MM-DD). Note: pour les users WAT (UTC+1) un commit tardif peut basculer au jour suivant.
  commitsByDay  Json?

  // ---- Alertes de deadline déjà envoyées (pour éviter les doublons) ----
  // Format: ["J-7", "J-3", "J-1"]
  deadlineAlertsNotified Json?

  trophies    Trophy[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MissionStatus {
  IN_PROGRESS
  SHIPPED
  FAILED
}

// ---------- Trophées ----------
model Trophy {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  missionId   String   @db.ObjectId
  mission     Mission  @relation(fields: [missionId], references: [id])

  type        TrophyType
  awardedAt   DateTime @default(now())

  @@unique([missionId, type])
}

// TrophyType — Les valeurs restent identiques en base (ne pas renommer).
// Affichage Baobab : FIRST_COMMIT -> Premiere Graine plantee, FIRST_DEPLOY -> Premiere Pousse,
// FIFTY_COMMITS -> Racines qui s'enfoncent, HUNDRED_COMMITS -> Feuillage dense,
// SHIPPED -> Fruit recolte, EARLY_BIRD -> Premier au Cercle
enum TrophyType {
  FIRST_COMMIT
  FIRST_DEPLOY
  FIFTY_COMMITS
  HUNDRED_COMMITS
  SHIPPED
  EARLY_BIRD
}

// ---------- Paiement ----------
model Payment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  amount      Int
  status      PaymentStatus @default(PENDING)
  fedapayId   String? @unique
  paidAt      DateTime?

  createdAt   DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ---------- NextAuth ----------
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
