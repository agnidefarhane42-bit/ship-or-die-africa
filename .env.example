# ===== Database =====
DATABASE_URL="mongodb://..."  # MongoDB connection string

# ===== NextAuth =====
NEXTAUTH_SECRET="generer-avec: openssl rand -base64 32"
NEXTAUTH_URL="https://ton-domaine.vercel.app"

# ===== GitHub (pour tracker les commits) =====
GITHUB_ACCESS_TOKEN="ghp_..."  # Personal Access Token (GitHub Settings > Developer settings > Tokens)

# ===== GitHub OAuth (pour vérifier l'identité GitHub des utilisateurs) =====
# GitHub Settings > Developer settings > OAuth Apps > New OAuth App
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID="..."  # OAuth App Client ID
GITHUB_CLIENT_SECRET="..."  # OAuth App Client Secret

# ===== FedaPay (Mobile Money) =====
FEDAPAY_SECRET_KEY="sk_..."
FEDAPAY_PUBLIC_KEY="pk_..."
FEDAPAY_ENVIRONMENT="sandbox"  # ou "live"
# Webhook secret : Dashboard FedaPay > Workbench > Webhooks > sélectionner l'endpoint > "Click to reveal"
FEDAPAY_WEBHOOK_SECRET="wh_..."  # Secret pour vérifier les signatures du webhook

# ===== Cohorte =====
COHORT_PRICE_XOF="10000"  # Prix d'entrée en FCFA (10.000 par défaut)

# ===== Cron (sync-missions + notify) =====
CRON_SECRET="generer-avec: openssl rand -base64 32"  # Secret pour protéger les routes /api/cron/*

# ===== Resend (emails) =====
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Ship or Die Africa <onboarding@resend.dev>"

# ===== Telegram Bot (notifications) =====
# 1. Va sur Telegram → cherche @BotFather → /newbot → choisis un nom et username
# 2. Récupère le token donné par BotFather
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# 3. Génère un secret pour protéger le webhook : openssl rand -base64 32
TELEGRAM_WEBHOOK_SECRET="..."
# 4. Configure le webhook (une seule fois) :
#    curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook?url=https://ton-domaine.vercel.app/api/telegram/webhook&secret_token=${TELEGRAM_WEBHOOK_SECRET}"
# 5. (Optionnel) Définis le username du bot pour les liens de liaison :
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="ShipOrDieAfricaBot"

# ===== Telegram Group (groupe de la communauté) =====
# 1. Crée un groupe Telegram manuellement, ajoute le bot comme administrateur
#    avec le droit "Post Messages"
# 2. Récupère le chat ID du groupe (négatif, ex: -100123456789) :
#    - Méthode A : ajoute temporairement @getidsbot au groupe, il répondra avec le chat ID
#    - Méthode B : envoie un message dans le groupe, puis appelle
#      curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates"
#      et cherche "chat": {"id": -100...} dans la réponse
# 3. Retire @getidsbot du groupe une fois l'ID récupéré (méthode A)
# 4. Crée un lien d'invitation public (ou via le bot) et mets-le ci-dessous
TELEGRAM_GROUP_CHAT_ID="-100123456789"
TELEGRAM_GROUP_INVITE_LINK="https://t.me/+abc..."
# Version publique du lien d'invitation (exposée côté client, ex: bouton "Rejoindre le groupe")
NEXT_PUBLIC_TELEGRAM_GROUP_INVITE_LINK="https://t.me/+abc..."

# ===== Vercel Blob (avatars) =====
# Généré automatiquement quand tu attaches un Blob Store au projet :
# Vercel Dashboard → Storage → Create Database → Blob
# En local : vercel env pull
BLOB_READ_WRITE_TOKEN=""
